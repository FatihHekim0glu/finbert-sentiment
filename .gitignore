# --------------------------------------------------------------------------- #
# Model artifacts                                                              #
# --------------------------------------------------------------------------- #
# Torch / HF training intermediates and saved checkpoints are NEVER committed...
*.bin
*.pt
*.pth
*.safetensors
*.ckpt
checkpoints/
hf_cache/
runs/
# ...but the SHIPPED serve artifacts ARE committed (they ride in the wheel and
# the vendored API package): the int8 ONNX graph, the tokenizer.json, and the
# offline-measured metrics.json. Do NOT ignore these.
!src/finbert_sentiment/artifacts/*.onnx
!src/finbert_sentiment/artifacts/tokenizer.json
!src/finbert_sentiment/artifacts/metrics.json

# --------------------------------------------------------------------------- #
# HuggingFace datasets / data cache (never commit raw corpora)                 #
# --------------------------------------------------------------------------- #
*.parquet
*.arrow
.cache/
data_cache/

# --------------------------------------------------------------------------- #
# Notebooks                                                                     #
# --------------------------------------------------------------------------- #
.ipynb_checkpoints/

